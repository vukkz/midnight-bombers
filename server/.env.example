# Copy to server/.env for local development.
# On Railway, set these in the service Variables tab (no .env file needed).

# Required — Atlas connection string (used by the app and migrate:atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/midnightbombers?retryWrites=true&w=majority

# Optional — only for migrate:atlas (defaults to local midnight-bombers DB)
# LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/midnight-bombers
JWT_SECRET=replace-with-a-long-random-string

# Optional in production — auto-detected from RAILWAY_PUBLIC_DOMAIN on Railway
# CLIENT_URL=https://your-app.up.railway.app
NODE_ENV=production

# Optional — defaults shown
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@midnightbombers.com
ADMIN_PASSWORD=ChangeMe123!

# Email — Railway Hobby blocks SMTP (Gmail/nodemailer won't work there).
# Use Resend HTTP API in production (works on all Railway plans):
#   1. Sign up at https://resend.com
#   2. Create an API key
#   3. For testing use onboarding@resend.dev as sender (sends only to your Resend account email)
#   4. For production verify your domain in Resend and set RESEND_FROM to e.g. orders@yourdomain.com
RESEND_API_KEY=re_...
RESEND_FROM="Midnight Bombers <onboarding@resend.dev>"
OWNER_EMAIL=your@gmail.com

# Optional — local dev only (Gmail SMTP via nodemailer; blocked on Railway Hobby)
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Stripe — required for embedded checkout
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret (from Dashboard → Developers → Webhooks → your endpoint).
# For local dev use the Stripe CLI: stripe listen --forward-to localhost:5000/api/checkout/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Also expose the publishable key to the Vite client build (same value as STRIPE_PUBLISHABLE_KEY).
# Set this in client/.env or in Railway as a build-time variable on the client service.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
