# Copy to server/.env for local development.
# On Railway, set these in the service Variables tab (no .env file needed).

# Required — Atlas connection string (used by the app and migrate:atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/midnightbombers?retryWrites=true&w=majority

# Optional — only for migrate:atlas (defaults to local midnight-bombers DB)
# LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/midnight-bombers
JWT_SECRET=replace-with-a-long-random-string

# Optional in production — auto-detected from RAILWAY_PUBLIC_DOMAIN on Railway
# CLIENT_URL=https://your-app.up.railway.app
NODE_ENV=production

# Optional — defaults shown
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@midnightbombers.com
ADMIN_PASSWORD=ChangeMe123!

# Optional — contact form & newsletter (Gmail app password)
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
OWNER_EMAIL=your@gmail.com
